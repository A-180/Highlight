local ps = game:GetService("Players")
local rs = game:GetService("RunService")
local workspace = game.Workspace

local darkPurple = Color3.new( 0.4, 0, 4.0 )

local function newHighlight()
	local h = Instance.new("Highlight")
	h.Name = "DarkPurpleBody"
	h.FillColor   = darkPurple
	h.OutlineColor= darkPurple
	h.FillTransparency   = 1      -- só quer o contorno
	h.OutlineTransparency= 0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- visível através de paredes
	h.Enabled = true
	return h
end

local function applyToModel(model)
	if not model then return end
	if model:FindFirstChild("DarkPurpleBody") then return end
	
	-- Verifica se o modelo tem um Humanoid
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	
	local h = newHighlight()
	h.Adornee = model -- fixa o tamanho exato do model Humanoid
	h.Parent  = model
end

-- Função para aplicar a todos os jogadores
local function onPlayer(p)
	p.CharacterAdded:Connect(function(char)
		applyToModel(char)
	end)
	if p.Character then applyToModel(p.Character) end
end

-- Função para buscar todos os Humanoids no workspace
local function scanAllHumanoids()
	-- Busca todos os descendentes do workspace
	for _, obj in ipairs(workspace:GetDescendants()) do
		-- Verifica se tem Humanoid
		local humanoid = obj:FindFirstChildOfClass("Humanoid")
		if humanoid then
			applyToModel(obj)
		end
	end
end

-- Conecta eventos de jogadores
ps.PlayerAdded:Connect(onPlayer)
for _,p in ipairs(ps:GetPlayers()) do onPlayer(p) end

-- Executa uma verificação inicial para pegar todos os Humanoids existentes
scanAllHumanoids()

---// FullBright + NoFog (Client)
--// Coloque em StarterPlayerScripts
--// Desenvolvido para baixo consumo de desempenho.

local Lighting = game:GetService("Lighting")

local CONFIG = {
    Brightness = 0.5,
    ClockTime = 8,
    Ambient = Color3.fromRGB(255,255,255),
    OutdoorAmbient = Color3.fromRGB(255,255,255),
    EnvironmentDiffuseScale = 1,
    EnvironmentSpecularScale = 1,
    ExposureCompensation = 1,
    FogStart = 1000000,
    FogEnd = 1000001,
    FogColor = Color3.fromRGB(255,255,255),
    GlobalShadows = false
}

local updating = false

local function removeEffect(effect)
    if effect:IsA("Atmosphere") then
        effect.Density = 0
        effect.Haze = 0
        effect.Glare = 0
        effect.Decay = Color3.new(1,1,1)
    elseif effect:IsA("BloomEffect")
        or effect:IsA("SunRaysEffect")
        or effect:IsA("DepthOfFieldEffect")
        or effect:IsA("ColorCorrectionEffect") then

        effect.Enabled = false
    end
end

local function applyLighting()
    if updating then
        return
    end

    updating = true

    Lighting.Brightness = CONFIG.Brightness
    Lighting.ClockTime = CONFIG.ClockTime
    Lighting.Ambient = CONFIG.Ambient
    Lighting.OutdoorAmbient = CONFIG.OutdoorAmbient
    Lighting.EnvironmentDiffuseScale = CONFIG.EnvironmentDiffuseScale
    Lighting.EnvironmentSpecularScale = CONFIG.EnvironmentSpecularScale
    Lighting.ExposureCompensation = CONFIG.ExposureCompensation

    Lighting.FogStart = CONFIG.FogStart
    Lighting.FogEnd = CONFIG.FogEnd
    Lighting.FogColor = CONFIG.FogColor

    Lighting.GlobalShadows = CONFIG.GlobalShadows

    for _,v in ipairs(Lighting:GetChildren()) do
        removeEffect(v)
    end

    updating = false
end

-- Primeira aplicação
applyLighting()

-- Novos efeitos adicionados
Lighting.ChildAdded:Connect(function(child)
    task.defer(function()
        removeEffect(child)
    end)
end)

-- Se alguma propriedade mudar, reaplica apenas uma vez
Lighting.Changed:Connect(function()
    applyLighting()
end)

